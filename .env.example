# --- AWS / Bedrock ---
# Credentials come from the default AWS credential chain (env, shared config, SSO, role).
AWS_REGION=ap-south-1
# In ap-south-1 Nova Pro is INFERENCE_PROFILE-only; use the APAC inference profile id.
BEDROCK_MODEL_ID=apac.amazon.nova-pro-v1:0

# --- Data layer ---
# false = in-memory + JSON-file mock store; true = real MongoDB Atlas + Vector Search.
USE_REAL_ATLAS=false
# Replace with your own Atlas SRV connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pilotrescue?appName=pilot-rescue-kit

# --- Server ---
PORT=3000
